+// --------------------------------------------------------------------------- //
+//
+//	ROUTINE:	CCharacter::ProcessEnhancedGoreDamage()
+//
+//	PURPOSE:	Allow bounded, location-specific corpse severing without
+//				re-entering destructible death, scoring, or death commands.
+//
+// --------------------------------------------------------------------------- //
+bool CCharacter::ProcessEnhancedGoreDamage(const DamageStruct& rDamage)
+{
+	if (IsMultiplayerGameServer() || !IsEnhancedGoreEnabled() ||
+		!g_pGameServerShell || !g_pGameServerShell->IsGoreAllowed() ||
+		m_cs.bIsPlayer ||
+		!m_damage.IsDead() || !m_bStartedDeath ||
+		m_bGibbed || m_bDeathEffect || rDamage.fDamage <= 0.0f || rDamage.fDuration > 0.0f ||
+		rDamage.eType == DT_INVALID || rDamage.eType == DT_WORLDONLY ||
+		m_damage.IsCantDamageType(rDamage.eType) || !m_bModelNodeHitPending)
+	{
+		return false;
+	}
+
+	if (GetEnhancedGoreSeverCount() >= GetEnhancedGoreMaxSeversPerBody())
+	{
+		return false;
+	}
+
+	if (!m_bIsOnSeveredList &&
+		(sm_nSeverCounter > 0 || m_lstSeverBodies.size() >= g_pServerDB->GetSeverTotalCap()))
+	{
+		return false;
+	}
+
+	ModelsDB::HSEVERBODY hBody = g_pModelsDB->GetSeverBodyRecord(m_hModel);
+	if (!hBody || !m_hModelNodeLastHit)
+	{
+		return false;
+	}
+
+	HitLocation eHitLocation = g_pModelsDB->GetNodeLocation(m_hModelNodeLastHit);
+	if (eHitLocation <= HL_UNKNOWN || eHitLocation >= HL_NUM_LOCS ||
+		HasEnhancedGoreSeveredLocation(eHitLocation))
+	{
+		return false;
+	}
+
+	if (IsKnockedDown() ||
+		(IsCrouched() && (eHitLocation == HL_TORSO || eHitLocation == HL_LEG_LEFT || eHitLocation == HL_LEG_RIGHT)))
+	{
+		return false;
+	}
+
+	// CDestructible has already rejected repeat death handling before this call.
+	// Only the gore tracker consumes this damage; hit points, score and commands
+	// are deliberately untouched.
+	m_EnhancedGoreDamageTracker.ProcessDamage(rDamage);
+
+	ModelsDB::HPieceArray hSeveredPieces;
+	uint32 nNumPieces = g_pModelsDB->GetBodyNumPieces(hBody);
+	hSeveredPieces.reserve(nNumPieces);
+	for (uint32 nPiece = 0; nPiece < nNumPieces; ++nPiece)
+	{
+		ModelsDB::HSEVERPIECE hSeveredPiece = g_pModelsDB->GetBodyPiece(hBody, nPiece);
+		if (hSeveredPiece && HasEnhancedGoreSeveredLocation(g_pModelsDB->GetSPLocation(hSeveredPiece)))
+		{
+			hSeveredPieces.push_back(hSeveredPiece);
+		}
+	}
+
+	ModelsDB::HSEVERPIECE hPiece = m_EnhancedGoreDamageTracker.CheckForSeverAtLocation(hBody, eHitLocation, hSeveredPieces);
+	if (!hPiece)
+	{
+		return true;
+	}
+
+	ScheduleSeveredAIUpdate(m_hObject);
+
+	if (!m_bSevered)
+	{
+		m_bSevered = true;
+		PrepareToSever();
+	}
+
+	if (!m_bIsOnSeveredList)
+	{
+		// Match stock admission pacing for the first sever on a body.  Once a
+		// corpse is admitted, its per-corpse limit governs additional locations.
+		sm_nSeverCounter = g_pServerDB->GetSeverFrequencyCap();
+		if (g_vtBodySeverTest.GetFloat() > 0.0f)
+		{
+			sm_nSeverCounter = 0;
+		}
+
+		m_bIsOnSeveredList = true;
+		m_lstSeverBodies.push_back(this);
+	}
+
+	HandleSeverWithImpulse(hPiece, rDamage.GetDamageDir(), rDamage.fImpulseForce);
+	return true;
+}
+
+bool CCharacter::HasEnhancedGoreSeveredLocation(HitLocation eLocation) const
+{
+	if (eLocation <= HL_UNKNOWN || eLocation >= HL_NUM_LOCS)
+	{
+		return false;
+	}
+
+	return ((m_nEnhancedGoreSeveredLocations & (1 << eLocation)) != 0);
+}
+
+void CCharacter::MarkEnhancedGoreSeveredLocation(HitLocation eLocation)
+{
+	if (eLocation > HL_UNKNOWN && eLocation < HL_NUM_LOCS)
+	{
+		m_nEnhancedGoreSeveredLocations |= (1 << eLocation);
+	}
+}
+
+uint32 CCharacter::GetEnhancedGoreSeverCount() const
+{
+	uint32 nCount = 0;
+	for( uint32 nLocation = HL_HEAD; nLocation < HL_NUM_LOCS; ++nLocation )
+	{
+		if( HasEnhancedGoreSeveredLocation( static_cast<HitLocation>( nLocation )))
+		{
+			++nCount;
+		}
+	}
+
+	return nCount;
+}
+
+void CCharacter::ReplayEnhancedGoreSeversToClient( HCLIENT hClient )
+{
+	if( !hClient || m_nEnhancedGoreSeveredLocations == 0 ||
+		( m_nEnhancedGoreSeveredLocations & kEnhancedGoreImpreciseSeverMask ))
+	{
+		return;
+	}
+
+	// Detached pieces are client objects and are not serialized by the server.
+	// Replay the stock message once the replacement CharacterFX is in-world.
+	// A unit direction plus zero force gives the reconstructed part no impulse.
+	const LTVector vNeutralSeverDir( 0.0f, 1.0f, 0.0f );
+	for( uint32 nLocation = HL_HEAD; nLocation < HL_NUM_LOCS; ++nLocation )
+	{
+		HitLocation eLocation = static_cast<HitLocation>( nLocation );
+		if( HasEnhancedGoreSeveredLocation( eLocation ))
+		{
+			SendSeverMessage( hClient, eLocation, vNeutralSeverDir, 0.0f );
+		}
+	}
+}
