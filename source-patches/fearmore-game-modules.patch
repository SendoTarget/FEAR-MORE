+static bool HandleFearMoreSinglePlayerCVar( HCLIENT hSender, char const* pszCommand )
+{
+	ConParse parse;
+	parse.Init( pszCommand );
+	if( g_pCommonLT->Parse( &parse ) != LT_OK || parse.m_nArgs == 0 ||
+		!LTStrIEquals( parse.m_Args[0], FearMoreRuntimeControls::kForwardCommand ))
+	{
+		return false;
+	}
+
+	// Consume malformed or unauthorized forms of this private command instead
+	// of falling through to the general command manager.  This bridge is only
+	// for the in-process single-player server, in every build configuration.
+	if( parse.m_nArgs != 3 || !hSender ||
+		!( g_pLTServer->GetClientInfoFlags( hSender ) & CIF_LOCAL ) ||
+		IsMultiplayerGameServer( ))
+	{
+		return true;
+	}
+
+	char const* pszAllowedVariable = NULL;
+	for( uint32 nVariable = 0; nVariable < LTARRAYSIZE( FearMoreRuntimeControls::kForwardedVariables ); ++nVariable )
+	{
+		if( LTStrIEquals( parse.m_Args[1], FearMoreRuntimeControls::kForwardedVariables[nVariable] ))
+		{
+			pszAllowedVariable = FearMoreRuntimeControls::kForwardedVariables[nVariable];
+			break;
+		}
+	}
+
+	if( pszAllowedVariable )
+	{
+		char* pszValueEnd = NULL;
+		double fParsedValue = strtod( parse.m_Args[2], &pszValueEnd );
+		if( pszValueEnd != parse.m_Args[2] && pszValueEnd && *pszValueEnd == '\0' &&
+			_finite( fParsedValue ) && fParsedValue >= -FLT_MAX && fParsedValue <= FLT_MAX )
+		{
+			g_pLTServer->SetConsoleVariableFloat( pszAllowedVariable, (float)fParsedValue );
+		}
+	}
+
+	return true;
+}
