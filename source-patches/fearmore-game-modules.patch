+// ----------------------------------------------------------------------- //
+//
+//	ROUTINE:	DamageTracker::Save()/Load()
+//
+//	PURPOSE:	Persist accumulated damage without exposing tracker internals.
+//
+// ----------------------------------------------------------------------- //
+void DamageTracker::Save(ILTMessage_Write* pMsg) const
+{
+	for (uint32 nDamageType = 0; nDamageType < kNumDamageTypes; ++nDamageType)
+	{
+		pMsg->Writefloat(m_Records[nDamageType].fTotal);
+		for (uint32 nLocation = 0; nLocation < HL_NUM_LOCS; ++nLocation)
+		{
+			pMsg->Writefloat(m_Records[nDamageType].fLocation[nLocation]);
+		}
+	}
+}
+
+void DamageTracker::Load(ILTMessage_Read* pMsg)
+{
+	for (uint32 nDamageType = 0; nDamageType < kNumDamageTypes; ++nDamageType)
+	{
+		m_Records[nDamageType].fTotal = pMsg->Readfloat();
+		for (uint32 nLocation = 0; nLocation < HL_NUM_LOCS; ++nLocation)
+		{
+			m_Records[nDamageType].fLocation[nLocation] = pMsg->Readfloat();
+		}
+	}
+}
