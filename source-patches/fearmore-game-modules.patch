+// ----------------------------------------------------------------------- //
+//
+//	ROUTINE:	CPlayerCamera::UpdateScriptedLureCinematicSideMask()
+//
+//	PURPOSE:	Bound authored first-person PlayerLure presentations without
+//				changing interactive lures or CameraFX type semantics.
+//
+// ----------------------------------------------------------------------- //
+
+void CPlayerCamera::UpdateScriptedLureCinematicSideMask( bool bLiveCinematicCamera )
+{
+	FearMoreCameraProbe::CinematicSideMaskState diagnosticState;
+	diagnosticState.m_nCameraMode = static_cast<int>( GetCameraMode() );
+	diagnosticState.m_bLiveCinematicCamera = bLiveCinematicCamera;
+
+	PlayerLureFX* pPlayerLureFX = NULL;
+	CVehicleMgr* pVehicleMgr = g_pMoveMgr ? g_pMoveMgr->GetVehicleMgr() : NULL;
+	if( pVehicleMgr && pVehicleMgr->IsVehiclePhysics() )
+	{
+		diagnosticState.m_bVehiclePhysics = true;
+		diagnosticState.m_nPlayerLureId = pVehicleMgr->GetPlayerLureId();
+		pPlayerLureFX = PlayerLureFX::GetPlayerLureFX( diagnosticState.m_nPlayerLureId );
+	}
+
+	if( pPlayerLureFX )
+	{
+		diagnosticState.m_bPlayerLureFxValid = true;
+		diagnosticState.m_nCameraFreedom = static_cast<int>( pPlayerLureFX->GetCameraFreedom() );
+		diagnosticState.m_bAllowWeapon = pPlayerLureFX->GetAllowWeapon();
+		diagnosticState.m_bAllowSwitchWeapon = pPlayerLureFX->GetAllowSwitchWeapon();
+		diagnosticState.m_bRetainOffsets = pPlayerLureFX->GetRetainOffsets();
+		diagnosticState.m_bTrackPitch = pPlayerLureFX->GetTrackPitch();
+		diagnosticState.m_bTrackYaw = pPlayerLureFX->GetTrackYaw();
+		diagnosticState.m_bAllowBodyRotation = pPlayerLureFX->GetAllowBodyRotation();
+	}
+
+	diagnosticState.m_bPlayingSpecial = CPlayerBodyMgr::Instance().IsPlayingSpecial();
+	diagnosticState.m_bAuthoredCrosshairEnabled = !g_pCrosshair || g_pCrosshair->IsEnabled();
+	diagnosticState.m_bSideMaskRequested =
+		( m_hTarget && !bLiveCinematicCamera && pPlayerLureFX &&
+		  diagnosticState.m_bPlayingSpecial && !diagnosticState.m_bAuthoredCrosshairEnabled );
+
+	g_pInterfaceMgr->SetCinematicSideMask( diagnosticState.m_bSideMaskRequested );
+	FearMoreCameraProbe::RecordCinematicSideMaskState( diagnosticState );
