+void CScreenGame::UpdateHDTextureHelpId()
+{
+	if (!m_pHDTexturesCtrl)
+	{
+		return;
+	}
+
+	const char* szHelpId = kHDTexturesOffHelpId;
+	if (m_nHDTextures == 1)
+	{
+		szHelpId = kHDTexturesLiteHelpId;
+	}
+	else if (m_nHDTextures == 2)
+	{
+		szHelpId = kHDTexturesFullHelpId;
+	}
+	m_pHDTexturesCtrl->SetHelpID(szHelpId);
+}
+
+void CScreenGame::GetHelpString(const char* szHelpId, uint16 nControlIndex, wchar_t *buffer, int bufLen)
+{
+	if (LTStrIEquals(szHelpId, kEnhancedGoreHelpId))
+	{
+		LTStrCpy(buffer, L"Adds bounded postmortem limb damage using F.E.A.R.'s original gore assets. Standard Gore must also be Yes. Changes apply on the next world load.", bufLen);
+		return;
+	}
+
+	if (LTStrIEquals(szHelpId, kCorpsePersistenceHelpId))
+	{
+		LTStrCpy(buffer,
+			L"Single player only. Keeps bounded bodies, blood and bullet decals, shell casings, shattered surfaces, and selected debris "
+			L"for the loaded level. Old effects are recycled at their limits; Off uses F.E.A.R.'s original lifetimes and body limits. "
+			L"Changes apply on the next world load.",
+			bufLen);
+		return;
+	}
+
+	if (LTStrIEquals(szHelpId, kHDTexturesOffHelpId) ||
+		LTStrIEquals(szHelpId, kHDTexturesLiteHelpId) ||
+		LTStrIEquals(szHelpId, kHDTexturesFullHelpId))
+	{
+		const int nSelectedMode = (int)LTCLAMP(m_nHDTextures, 0, 2);
+		const int nActiveMode = LTCLAMP(GetConsoleInt("FearMoreHDTexturesActive", 0), 0, 2);
+		if (nSelectedMode != nActiveMode)
+		{
+			LTStrCpy(buffer, L"The selected HD texture mode applies on the next launch. Exit and restart through Launch FearMore.", bufLen);
+		}
+		else if (nActiveMode == 1)
+		{
+			LTStrCpy(buffer, L"Stable Lite is active. It overlays Rivarez's official reduced textures for better transition stability with a small quality tradeoff.", bufLen);
+		}
+		else if (nActiveMode == 2)
+		{
+			LTStrCpy(buffer, L"Full v2.0.2 is experimental. It has reproduced a d3dx9 crash during a level transition; Stable Lite is recommended.", bufLen);
+		}
+		else
+		{
+			LTStrCpy(buffer, L"Optional HD textures are off. Select Stable Lite and restart through Launch FearMore to use the recommended pack.", bufLen);
+		}
+		return;
+	}
+
+	CBaseScreen::GetHelpString(szHelpId, nControlIndex, buffer, bufLen);
+}
+
