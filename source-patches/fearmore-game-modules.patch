+void CInterfaceResMgr::GetAspectConstrainedRect(const LTRect2f& screenBounds,
+	float fMaxAspect, LTRect2f& constrainedBounds) const
+{
+	constrainedBounds = screenBounds;
+
+	const float fWidth = screenBounds.m_vMax.x - screenBounds.m_vMin.x;
+	const float fHeight = screenBounds.m_vMax.y - screenBounds.m_vMin.y;
+	if (fWidth <= 0.0f || fHeight <= 0.0f || fMaxAspect <= 0.0f)
+		return;
+
+	const float fConstrainedWidth = fHeight * fMaxAspect;
+	// Treat sub-pixel differences as the same aspect ratio so matching modes
+	// keep their exact legacy bounds after floating-point conversion.
+	if (fWidth <= fConstrainedWidth + 0.5f)
+		return;
+
+	const float fHorizontalInset = (fWidth - fConstrainedWidth) * 0.5f;
+	constrainedBounds.m_vMin.x += fHorizontalInset;
+	constrainedBounds.m_vMax.x -= fHorizontalInset;
+}
+
+void CInterfaceResMgr::GetHUDSafeAreaTransform(const LTRect2f& screenBounds,
+	LTRect2f& safeBounds, LTVector2& safeScale) const
+{
+	safeBounds = screenBounds;
+	safeScale = m_vfScale;
+
+	// Allow players to retain the original full-width placement.  VarTrack
+	// keeps a value supplied by a command line or configuration file.
+	if (s_vtHUDSafeAreaFullWidth.GetFloat() != 0.0f)
+		return;
+
+	GetAspectConstrainedRect(screenBounds, kHUDSafeAreaMaxAspect, safeBounds);
+
+	const float fWidth = screenBounds.m_vMax.x - screenBounds.m_vMin.x;
+	const float fSafeWidth = safeBounds.m_vMax.x - safeBounds.m_vMin.x;
+	if (fWidth > 0.0f)
+		safeScale.x *= fSafeWidth / fWidth;
+}
