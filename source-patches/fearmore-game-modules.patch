@@ -233,0 +265,63 @@ bool DamageTracker::CheckForSever(ModelsDB::HSEVERBODY hBody, bool bIsCrouched,
+
+// ----------------------------------------------------------------------- //
+//
+//	ROUTINE:	DamageTracker::CheckForSeverAtLocation()
+//
+//	PURPOSE:	Test accumulated damage for one explicitly hit location.
+//
+// ----------------------------------------------------------------------- //
+ModelsDB::HSEVERPIECE DamageTracker::CheckForSeverAtLocation(ModelsDB::HSEVERBODY hBody, HitLocation eLocation,
+	const ModelsDB::HPieceArray& hSeveredPieces)
+{
+	if (!hBody || eLocation <= HL_UNKNOWN || eLocation >= HL_NUM_LOCS)
+	{
+		return NULL;
+	}
+
+	uint32 nNumPieces = g_pModelsDB->GetBodyNumPieces(hBody);
+	for (uint32 nPiece = 0; nPiece < nNumPieces; ++nPiece)
+	{
+		ModelsDB::HSEVERPIECE hPiece = g_pModelsDB->GetBodyPiece(hBody, nPiece);
+		if (!hPiece || g_pModelsDB->GetSPLocation(hPiece) != eLocation)
+		{
+			continue;
+		}
+
+		bool bFoundExclusion = false;
+		ModelsDB::HPieceArray::const_iterator iterSeveredPiece = hSeveredPieces.begin();
+		while (iterSeveredPiece != hSeveredPieces.end() && !bFoundExclusion)
+		{
+			bFoundExclusion = g_pModelsDB->IsExcludedPiece(hPiece, *iterSeveredPiece);
+			++iterSeveredPiece;
+		}
+
+		if (bFoundExclusion)
+		{
+			continue;
+		}
+
+		ModelsDB::HSEVERDAMAGE hSeverDamage = g_pModelsDB->GetSPDamageRecord(hPiece);
+		if (!hSeverDamage)
+		{
+			continue;
+		}
+
+		for (uint32 nDamageType = 0; nDamageType < kNumDamageTypes; ++nDamageType)
+		{
+			DamageType eDamageType = static_cast<DamageType>(nDamageType);
+			float fDamage = m_Records[eDamageType].fLocation[eLocation];
+			if (fDamage <= 0.0f)
+			{
+				continue;
+			}
+
+			float fChance = g_pModelsDB->GetSeverChance(hSeverDamage, eDamageType, fDamage);
+			if (GetRandom(0.0f, 1.0f) < fChance)
+			{
+				return hPiece;
+			}
+		}
+	}
+
+	return NULL;
+}
