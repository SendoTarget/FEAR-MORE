+// ----------------------------------------------------------------------- //
+//
+//	ROUTINE:	CScreenPerformance::ApplyRemasterQuality()
+//
+//	PURPOSE:	select the retail database's Maximum level for the proven
+//				remaster-quality options without changing any other option
+//
+// ----------------------------------------------------------------------- //
+bool CScreenPerformance::ApplyRemasterQuality()
+{
+	if (!FearMoreRemasterQuality::QueueMaximumPreset())
+	{
+		MBCreate mb;
+		mb.eType = LTMB_OK;
+		g_pInterfaceMgr->ShowMessageBox(
+			L"Remaster quality was not applied. A required retail performance option is missing or incompatible.",
+			&mb );
+		return false;
+	}
+
+	UpdateOverall(ePT_CPU);
+	UpdateOverall(ePT_GPU);
+	CheckResolutionMemory();
+	UpdateGPUColor();
+
+	MBCreate mb;
+	mb.eType = LTMB_OK;
+	g_pInterfaceMgr->ShowMessageBox(
+		L"Remaster quality is ready. Leave the Performance screen to apply and save the changes.",
+		&mb );
+	return true;
+}
