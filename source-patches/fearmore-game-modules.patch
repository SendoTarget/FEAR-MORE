+void CScreenJoystick::GetHelpString(const char* szHelpId, uint16 nControlIndex, wchar_t *buffer, int bufLen)
+{
+	if( LTStrIEquals( szHelpId, kControllerEnabledHelp ) )
+	{
+		if( !CFearMoreControllerMgr::Instance().IsRuntimeAvailable() )
+			LTStrCpy( buffer, L"The validated SDL3 runtime is unavailable. Keyboard and mouse remain active. Relaunch through Launch FearMore to revalidate; a missing or changed owned payload fails closed and requires a fresh stage.", bufLen );
+		else if( !CFearMoreControllerMgr::Instance().IsGamepadConnected() )
+			LTStrCpy( buffer, L"SDL3 is ready. Connect an Xbox, PlayStation, or Switch-compatible controller; hotplug is supported while the game is running.", bufLen );
+		else
+			LTStrCpy( buffer, L"Use the modern SDL3 controller path. Keyboard and mouse remain active at the same time.", bufLen );
+		return;
+	}
+	if( LTStrIEquals( szHelpId, kControllerSensitivityHelp ) )
+	{
+		LTStrCpy( buffer, L"Adjust right-stick aim speed. Aim remains normalized using real frame time at high refresh rates.", bufLen );
+		return;
+	}
+	if( LTStrIEquals( szHelpId, kControllerDeadZoneHelp ) )
+	{
+		LTStrCpy( buffer, L"Set the radial inner deadzone for both sticks. Increase it only if the camera or movement drifts.", bufLen );
+		return;
+	}
+	if( LTStrIEquals( szHelpId, kControllerInvertYHelp ) )
+	{
+		LTStrCpy( buffer, L"Invert controller vertical aim independently of the mouse invert setting.", bufLen );
+		return;
+	}
+	if( LTStrIEquals( szHelpId, kControllerRumbleHelp ) )
+	{
+		LTStrCpy( buffer, L"Route F.E.A.R.'s authored low- and high-frequency ClientFX vibration to the active SDL3 gamepad.", bufLen );
+		return;
+	}
+
+	CBaseScreen::GetHelpString( szHelpId, nControlIndex, buffer, bufLen );
+}
+
