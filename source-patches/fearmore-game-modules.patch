+void CClientFXMgr::EnforceFearMorePersistenceBudget(CBaseFX::EFearMorePersistenceClass eClass, uint32 nBudget)
+{
+	uint32 nCount = 0;
+	LTListIter<CClientFXInstance*> itInstance = m_FXInstanceList.Begin();
+	while(itInstance != m_FXInstanceList.End())
+	{
+		CClientFXInstance* pInstance = *itInstance;
+		itInstance++;
+
+		LTListIter<CBaseFX*> itFX = pInstance->m_ActiveFXList.Begin();
+		while(itFX != pInstance->m_ActiveFXList.End())
+		{
+			CBaseFX* pFX = *itFX;
+			itFX++;
+			if(pFX->IsActive() && !pFX->IsShuttingDown() &&
+				(pFX->GetFearMorePersistenceClass() == eClass))
+			{
+				nCount++;
+			}
+		}
+	}
+
+	while(nCount > nBudget)
+	{
+		bool bRemoved = false;
+		itInstance = m_FXInstanceList.Begin();
+		while((itInstance != m_FXInstanceList.End()) && !bRemoved)
+		{
+			CClientFXInstance* pInstance = *itInstance;
+			itInstance++;
+
+			LTListIter<CBaseFX*> itFX = pInstance->m_ActiveFXList.Begin();
+			while(itFX != pInstance->m_ActiveFXList.End())
+			{
+				CBaseFX* pFX = *itFX;
+				itFX++;
+				if(pFX->IsActive() && !pFX->IsShuttingDown() &&
+					(pFX->GetFearMorePersistenceClass() == eClass))
+				{
+					pInstance->DeleteFX(pFX);
+					bRemoved = true;
+					nCount--;
+					break;
+				}
+			}
+		}
+
+		if(!bRemoved)
+			break;
+	}
+}
